# ============================================================
# YAAI Agent — 环境变量模板
# 复制为 .env 并填入实际值
# ============================================================

# -------- LLM 模型 --------
# 大模型（Orchestrator 用，需要强推理能力）
LARGE_MODEL_URL=https://api.deepseek.com
LARGE_MODEL_NAME=deepseek-v4-pro
LARGE_MODEL_KEY=sk-your-key-here

# 小模型（子 Agent 用，速度优先）
SMALL_MODEL_URL=https://api.deepseek.com
SMALL_MODEL_NAME=deepseek-v4-flash
SMALL_MODEL_KEY=sk-your-key-here

# 视觉模型（截图理解、图片分析）
VISION_MODEL_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_MODEL_NAME=your-vision-model
VISION_MODEL_KEY=your-vision-key

# 嵌入模型（RAG 向量化）
EMBEDDING_MODEL_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL_NAME=your-embedding-model
EMBEDDING_MODEL_KEY=your-embedding-key

# -------- Java 后端 --------
BACKEND_BASE_URL=http://localhost:9876
AGENT_TOKEN=yaai-agent-your-token-here

# -------- MySQL（Agent 只读，业务读写走 Java 后端） --------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=yaai_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=your-password
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=10

# -------- Redis（Sa-Token 会话校验，可选） --------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=your-password

# -------- Neo4j（知识图谱） --------
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j

# -------- ChromaDB（向量检索，本地文件） --------
CHROMA_DB_PATH=./data/vector_store

# -------- RabbitMQ（消息队列，可选） --------
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# -------- Aliyun OSS（文件存储） --------
ALIYUN_OSS_ACCESS_KEY_ID=your-key
ALIYUN_OSS_ACCESS_KEY_SECRET=your-secret
ALIYUN_OSS_ENDPOINT=oss-cn-chengdu.aliyuncs.com
ALIYUN_OSS_BUCKET=your-bucket
ALIYUN_OSS_REGION=cn-chengdu
ALIYUN_OSS_BASE_URL=https://your-bucket.oss-cn-chengdu.aliyuncs.com/
ALIYUN_OSS_PREFIX=yaai-agent/

# -------- 邮件（通知/验证码，可选） --------
QQ_EMAIL_HOST=smtp.qq.com
QQ_EMAIL_USERNAME=your-email@qq.com
QQ_EMAIL_AUTH=your-auth-code
QQ_EMAIL_PORT=587

# -------- Agent 服务 --------
AGENT_HOST=0.0.0.0
AGENT_PORT=8080
